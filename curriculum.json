/* ==========================================
   STYLES.CSS - Main Stylesheet
   Duolingo-esque, Mobile-first Design
   ========================================== */

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

:root {
    /* Colors */
    --primary: #1a1a2e;
    --secondary: #16213e;
    --accent: #00d4ff;
    --accent-bright: #00ff41;
    --warning: #ffaa00;
    --danger: #ff006e;
    --success: #00ff41;
    --background: #0f3460;
    --card-bg: #16213e;
    --text: #ffffff;
    --text-dim: #b0b0b0;
    
    /* Spacing */
    --spacing-xs: 4px;
    --spacing-sm: 8px;
    --spacing-md: 16px;
    --spacing-lg: 24px;
    --spacing-xl: 32px;
    
    /* Transitions */
    --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    --transition-fast: all 0.15s ease-in-out;
}

/* ========== BODY ========== */
html, body {
    height: 100%;
    width: 100%;
}

body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Helvetica Neue', sans-serif;
    background: linear-gradient(135deg, var(--primary) 0%, var(--background) 100%);
    color: var(--text);
    overflow: hidden;
    font-size: 16px;
    line-height: 1.6;
}

/* ========== APP CONTAINER ========== */
.app-container {
    width: 100vw;
    height: 100vh;
    display: flex;
    flex-direction: column;
    position: relative;
}

#main-content {
    flex: 1;
    overflow-y: auto;
    overflow-x: hidden;
    -webkit-overflow-scrolling: touch; /* iOS smoothness */
    padding-bottom: 80px; /* Bottom nav space */
}

#main-content.hidden {
    display: none;
}

/* ========== LOADING SCREEN ========== */
.loading-screen {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: var(--primary);
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: var(--spacing-lg);
    z-index: 9999;
}

.spinner {
    width: 60px;
    height: 60px;
    border: 4px solid var(--card-bg);
    border-top: 4px solid var(--accent);
    border-radius: 50%;
    animation: spin 1s linear infinite;
}

@keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
}

.loading-screen p {
    color: var(--accent);
    font-size: 18px;
    font-weight: 600;
}

/* ========== HEADER ========== */
.header {
    background: var(--secondary);
    padding: var(--spacing-md);
    border-bottom: 2px solid var(--accent);
    display: flex;
    justify-content: space-between;
    align-items: center;
    position: sticky;
    top: 0;
    z-index: 100;
}

.header__title {
    font-size: 20px;
    font-weight: 700;
    color: var(--accent);
}

.header__stats {
    display: flex;
    gap: var(--spacing-md);
    font-size: 14px;
}

.stat {
    display: flex;
    align-items: center;
    gap: 4px;
}

.stat__icon {
    font-size: 18px;
}

.stat__value {
    font-weight: 600;
    color: var(--warning);
}

/* ========== CARDS ========== */
.card {
    background: var(--card-bg);
    border-radius: 12px;
    padding: var(--spacing-lg);
    margin: var(--spacing-md);
    border: 1px solid rgba(0, 212, 255, 0.2);
    transition: var(--transition);
    cursor: pointer;
}

.card:hover:not(.card--locked) {
    border-color: var(--accent);
    box-shadow: 0 0 20px rgba(0, 212, 255, 0.3);
    transform: translateY(-4px);
}

.card--locked {
    opacity: 0.6;
    cursor: not-allowed;
    filter: grayscale(50%);
}

.card--completed {
    border-color: var(--success);
}

.card--active {
    border-color: var(--accent);
    background: rgba(0, 212, 255, 0.1);
}

/* ========== ROADMAP / TOPIC PATH ========== */
.roadmap {
    padding: var(--spacing-lg);
}

.roadmap__title {
    font-size: 18px;
    font-weight: 700;
    margin-bottom: var(--spacing-lg);
    color: var(--accent);
}

.topics-container {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
    position: relative;
}

/* Vertical line connector */
.topics-container::before {
    content: '';
    position: absolute;
    left: 24px;
    top: 20px;
    bottom: 20px;
    width: 2px;
    background: linear-gradient(180deg, var(--accent) 0%, var(--secondary) 100%);
    z-index: 0;
}

.topic-item {
    display: flex;
    align-items: flex-start;
    gap: var(--spacing-md);
    position: relative;
    z-index: 1;
}

.topic-item__marker {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--secondary);
    border: 3px solid var(--secondary);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24px;
    flex-shrink: 0;
    transition: var(--transition-fast);
}

.topic-item.completed .topic-item__marker {
    background: var(--success);
    border-color: var(--accent);
    font-size: 16px;
}

.topic-item.active .topic-item__marker {
    background: var(--accent);
    border-color: var(--warning);
    box-shadow: 0 0 20px rgba(0, 212, 255, 0.6);
}

.topic-item.locked .topic-item__marker {
    opacity: 0.5;
}

.topic-item__content {
    flex: 1;
    padding-top: 6px;
}

.topic-item__name {
    font-size: 16px;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 4px;
}

.topic-item.locked .topic-item__name {
    color: var(--text-dim);
}

.topic-item__meta {
    font-size: 12px;
    color: var(--text-dim);
}

/* ========== INFO CARD (Bilgi Kartı) ========== */
.info-card {
    background: var(--card-bg);
    border-radius: 12px;
    padding: var(--spacing-lg);
    margin: var(--spacing-md);
    border: 1px solid rgba(0, 212, 255, 0.2);
    line-height: 1.8;
}

.info-card__title {
    font-size: 18px;
    font-weight: 700;
    color: var(--accent);
    margin-bottom: var(--spacing-md);
}

.info-card__text {
    color: var(--text);
    margin-bottom: var(--spacing-lg);
    font-size: 16px;
}

/* Interactive words (seçilebilir) */
.interactive-word {
    background: rgba(0, 212, 255, 0.2);
    border-bottom: 2px dashed var(--accent);
    cursor: pointer;
    transition: var(--transition-fast);
    padding: 2px 4px;
    border-radius: 3px;
}

.interactive-word:hover {
    background: rgba(0, 212, 255, 0.4);
}

/* Geographic references */
.geo-reference {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    background: rgba(255, 170, 0, 0.2);
    padding: 2px 6px;
    border-radius: 4px;
    cursor: pointer;
    transition: var(--transition-fast);
}

.geo-reference:hover {
    background: rgba(255, 170, 0, 0.4);
}

.geo-icon {
    font-size: 14px;
}

.info-card__geo-bridge {
    background: rgba(0, 212, 255, 0.1);
    border-left: 4px solid var(--accent);
    padding: var(--spacing-md);
    border-radius: 6px;
    margin-top: var(--spacing-md);
    font-style: italic;
    color: var(--text-dim);
}

/* ========== QUESTION SCREEN ========== */
.question-container {
    background: var(--card-bg);
    border-radius: 12px;
    padding: var(--spacing-lg);
    margin: var(--spacing-md);
    border: 1px solid rgba(0, 212, 255, 0.2);
}

.question-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--spacing-lg);
    font-size: 14px;
}

.question-progress {
    color: var(--accent);
    font-weight: 600;
}

.question-xp {
    color: var(--warning);
    font-weight: 600;
}

.question-text {
    font-size: 18px;
    font-weight: 600;
    color: var(--text);
    margin-bottom: var(--spacing-lg);
    line-height: 1.5;
}

.options {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
}

.option {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
    padding: var(--spacing-md);
    background: var(--secondary);
    border: 2px solid transparent;
    border-radius: 8px;
    cursor: pointer;
    transition: var(--transition-fast);
    font-size: 16px;
}

.option:hover {
    border-color: var(--accent);
    background: rgba(0, 212, 255, 0.1);
}

.option input[type="radio"] {
    width: 20px;
    height: 20px;
    cursor: pointer;
    accent-color: var(--accent);
}

.option.selected {
    border-color: var(--accent);
    background: rgba(0, 212, 255, 0.15);
}

.option.correct {
    border-color: var(--success);
    background: rgba(0, 255, 65, 0.15);
}

.option.incorrect {
    border-color: var(--danger);
    background: rgba(255, 0, 110, 0.15);
}

/* ========== FEEDBACK ========== */
.feedback {
    padding: var(--spacing-lg);
    border-radius: 8px;
    margin: var(--spacing-md) 0;
    font-size: 16px;
    line-height: 1.6;
}

.feedback--success {
    background: rgba(0, 255, 65, 0.2);
    border-left: 4px solid var(--success);
    color: var(--success);
}

.feedback--error {
    background: rgba(255, 0, 110, 0.2);
    border-left: 4px solid var(--danger);
    color: var(--danger);
}

.feedback--info {
    background: rgba(0, 212, 255, 0.2);
    border-left: 4px solid var(--accent);
    color: var(--accent);
}

.feedback__title {
    font-weight: 700;
    margin-bottom: 8px;
}

.feedback__text {
    font-size: 14px;
}

/* ========== BUTTONS ========== */
button, .btn {
    padding: var(--spacing-md) var(--spacing-lg);
    border: none;
    border-radius: 8px;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: var(--transition-fast);
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.btn--primary {
    background: var(--accent);
    color: var(--primary);
}

.btn--primary:hover {
    box-shadow: 0 0 20px rgba(0, 212, 255, 0.6);
    transform: translateY(-2px);
}

.btn--secondary {
    background: var(--secondary);
    color: var(--accent);
    border: 2px solid var(--accent);
}

.btn--secondary:hover {
    background: var(--accent);
    color: var(--primary);
}

.btn--success {
    background: var(--success);
    color: var(--primary);
}

.btn--success:hover {
    box-shadow: 0 0 20px rgba(0, 255, 65, 0.6);
}

.btn--danger {
    background: var(--danger);
    color: var(--text);
}

.btn--danger:hover {
    box-shadow: 0 0 20px rgba(255, 0, 110, 0.6);
}

.btn--large {
    width: 100%;
    padding: var(--spacing-lg) var(--spacing-xl);
    font-size: 18px;
    margin: var(--spacing-md) 0;
}

.btn--icon {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
}

.btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
}

/* ========== MODALS & OVERLAYS ========== */
.modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.7);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
    animation: fadeIn 0.2s ease-in;
}

.modal {
    background: var(--card-bg);
    border-radius: 12px;
    padding: var(--spacing-lg);
    max-width: 90%;
    max-height: 90vh;
    overflow-y: auto;
    border: 1px solid var(--accent);
    animation: slideUp 0.3s ease-out;
}

@keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
}

@keyframes slideUp {
    from {
        transform: translateY(100px);
        opacity: 0;
    }
    to {
        transform: translateY(0);
        opacity: 1;
    }
}

.modal__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--spacing-lg);
    border-bottom: 1px solid rgba(0, 212, 255, 0.2);
    padding-bottom: var(--spacing-md);
}

.modal__title {
    font-size: 20px;
    font-weight: 700;
    color: var(--accent);
}

.modal__close {
    background: none;
    border: none;
    color: var(--accent);
    font-size: 28px;
    cursor: pointer;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
}

.modal__close:hover {
    transform: scale(1.2);
}

.modal__content {
    margin-bottom: var(--spacing-lg);
}

/* ========== POPUP (Kelime Açıklaması) ========== */
.popup {
    position: absolute;
    background: var(--secondary);
    border: 2px solid var(--accent);
    border-radius: 8px;
    padding: var(--spacing-md);
    min-width: 200px;
    max-width: 300px;
    z-index: 500;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
    animation: popupAppear 0.2s ease-out;
}

@keyframes popupAppear {
    from {
        opacity: 0;
        transform: scale(0.9);
    }
    to {
        opacity: 1;
        transform: scale(1);
    }
}

.popup__word {
    font-size: 14px;
    font-weight: 700;
    color: var(--accent);
    margin-bottom: 8px;
}

.popup__text {
    font-size: 13px;
    color: var(--text);
    line-height: 1.5;
}

/* ========== BADGE ========== */
.badge {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding: var(--spacing-md);
    background: var(--card-bg);
    border: 2px solid var(--warning);
    border-radius: 12px;
    text-align: center;
}

.badge__icon {
    font-size: 32px;
}

.badge__name {
    font-size: 14px;
    font-weight: 600;
    color: var(--warning);
}

.badge--locked {
    opacity: 0.3;
    border-color: var(--text-dim);
}

/* ========== BOTTOM NAVIGATION ========== */
.bottom-nav {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    height: 70px;
    background: var(--secondary);
    border-top: 2px solid var(--accent);
    display: flex;
    justify-content: space-around;
    align-items: center;
    z-index: 100;
}

.nav-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    padding: 8px 12px;
    cursor: pointer;
    color: var(--text-dim);
    transition: var(--transition-fast);
    flex: 1;
    height: 100%;
    justify-content: center;
}

.nav-item:hover,
.nav-item.active {
    color: var(--accent);
}

.nav-item__icon {
    font-size: 24px;
}

.nav-item__label {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
}

/* ========== MAP CONTAINER ========== */
.map-container {
    width: 100%;
    height: 300px;
    border-radius: 8px;
    margin: var(--spacing-md);
    overflow: hidden;
    border: 1px solid var(--accent);
}

#map {
    width: 100%;
    height: 100%;
}

.leaflet-container {
    background: var(--secondary) !important;
}

.leaflet-popup-content-wrapper {
    background: var(--card-bg) !important;
    color: var(--text) !important;
    border: 1px solid var(--accent) !important;
}

.leaflet-popup-tip {
    background: var(--card-bg) !important;
}

/* ========== MISC ========== */
.hidden {
    display: none !important;
}

.visible {
    display: block !important;
}

.text-center {
    text-align: center;
}

.mt {
    margin-top: var(--spacing-md);
}

.mb {
    margin-bottom: var(--spacing-md);
}

.text-dim {
    color: var(--text-dim);
}

.text-accent {
    color: var(--accent);
}

.text-success {
    color: var(--success);
}

.text-danger {
    color: var(--danger);
}

.text-warning {
    color: var(--warning);
}
